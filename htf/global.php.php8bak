$starttime = $mtime[1] + $mtime[0];
empty($db_debug) && error_reporting(0);

/**
 * PHP 8 Compatibility: Removed register_globals emulation
 * Security: Input sanitization with whitelist approach
 */

// Input parameter whitelist
$_safe_get_params = ['fid', 'tid', 'action', 'step', 'page', 'skin', 'online', 'username', 'faqjob', 'searchkey'];
$_safe_post_params = ['step', 'action', 'loginuser', 'loginpwd', 'cktime', 'hideid', 'jumpurl',
                      'regname', 'regpwd', 'regemail', 'regsex', 'regoicq', 'reghomepage', 'regfrom',
                      'regintroduce', 'regsign', 'regifemail', 'regemailtoall', 'regbirthyear',
                      'regbirthmonth', 'regbirthday', 'atc_title', 'atc_content', 'atc_type',
                      'atc_email', 'vt_select'];

// Extract GET parameters
foreach($_safe_get_params as $_var) {
    if(isset($_GET[$_var])) {
        $$_var = $_GET[$_var];
    }
}

// Extract and sanitize POST parameters
foreach($_safe_post_params as $_var) {
    if(isset($_POST[$_var])) {
        // Sanitize: prevent delimiter injection
        $_POST[$_var] = str_replace('|', '　', str_replace('$', '&ensp;$', $_POST[$_var]));
        $$_var = $_POST[$_var];
    }
}

// Type-safe integer parameters
$fid = isset($fid) ? (int)$fid : 0;
$tid = isset($tid) ? (int)$tid : 0;

// PHP 8 compatible: null coalescing operator
$REQUEST_URI = $_SERVER['REQUEST_URI'] ?? $_SERVER['PHP_SELF'];

/**
 * IP Address Detection
 * Security: Validate against header injection
 */
if(!empty($_SERVER['HTTP_CLIENT_IP']) && filter_var($_SERVER['HTTP_CLIENT_IP'], FILTER_VALIDATE_IP)){
    $onlineip = $_SERVER['HTTP_CLIENT_IP'];
}elseif(!empty($_SERVER['HTTP_X_FORWARDED_FOR'])){
    // Take first IP from proxy chain
    $ip_list = explode(',', $_SERVER['HTTP_X_FORWARDED_FOR']);
    $onlineip = trim($ip_list[0]);
    if(!filter_var($onlineip, FILTER_VALIDATE_IP)){
        $onlineip = $_SERVER['REMOTE_ADDR'];
    }
}else{
    $onlineip = $_SERVER['REMOTE_ADDR'];
}
$onlineip = substrs($onlineip, 16);

