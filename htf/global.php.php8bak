$db_http != 'N' ? $imgpath = $db_http : $imgpath = './' . $picpath;
$htf_version = '1.0.7-php8';
$db_olsize = 96;

/**
 * Forum Closure Check
 */
if ($db_bbsifopen == 0) {
    session_set_cookie_params(0, $ckpath, $ckdomain);
    session_name('S');
    session_save_path('session');
    session_start();
    if ($_SESSION['htfadminid'] != $manager || $_SESSION['htfadminpwd'] != $manager_pwd) {
        showmsg($db_whybbsclose);
    }
}
unset($manager_pwd);

/**
 * Timestamp & Time Calculation
 */
$timestamp = time();
$db_cvtime != 0 && $timestamp = $timestamp + $db_cvtime * 60;
$cookietime = $timestamp + 31536000;
$td = floor($timestamp / 3600);
$t = getdate($timestamp);
$hour = $t['hours'];
$tdtime = ($td - $hour) * 3600;

/**
 * Online Time Tracking
 */
$addontime = 0;
$lastvisit = isset($_COOKIE['lastvisit']) ? (int)$_COOKIE['lastvisit'] : 0;
$onbbstime = $timestamp - $lastvisit;
if($onbbstime < 3600 && $db_ifonlinetime) {
    $addontime = 1;
}

/**
 * User Authentication
 */
$runfc = 'N';
$ol_offset = isset($_COOKIE['ol_offset']) ? (int)$_COOKIE['ol_offset'] : 0;
if($timestamp - $lastvisit > $db_onlinetime ||
   ($_COOKIE['lastfid'] ?? '') != '' && ($star_action ?? '') == 'hm' ||
   (isset($fid) && $fid != ($_COOKIE['lastfid'] ?? 0)))
{
    $runfc = 'Y';
    Cookie('lastfid', $fid);
    include "./require/userglobal.php";
}

// User login verification
$htfid = str_replace('..', '', $_COOKIE['htfid'] ?? '');
$htfpwd = $_COOKIE['htfpwd'] ?? '';
if($htfid != '' && file_exists("$userpath/$htfid.php") && strlen($htfpwd) >= 16) {
    $htfdb = userloginfo();
    $groupid = $htfdb[5];
    $userrvrc = floor($htfdb[17] / 10);
    if($runfc == 'Y' && $htfid != '')
    {
        Cookie('forum_online', '', 0);
        $gotnewmsg = getusermsg($htfid);
        $groupid = $htfdb[5] = savecheck($groupid);
        $alt_offset = addonlinefile($ol_offset, $htfdb[1]);
        if($alt_offset != $ol_offset) Cookie('ol_offset', $alt_offset, 0);
    }
} else {
    $groupid = 'guest';
    unset($htfdb);
    $htfid = '';
    if($runfc == 'Y')
    {
        $alt_offset = addguestfile($ol_offset);
        if($alt_offset != $ol_offset) Cookie('ol_offset', $alt_offset, 0);
    }
}

/**
 * Anti-Flood Protection
 */
if ($db_refreshtime != 0)
{
    if($REQUEST_URI == ($_COOKIE['lastpath'] ?? '') && $onbbstime < $db_refreshtime) {
        showmsg("操作提示禁止,原因:对于同一URL的刷新时间小于{$db_refreshtime}秒");
    }
    Cookie('lastpath', $REQUEST_URI);
}
Cookie('lastvisit', $timestamp);

/**
 * IP Ban Check
 */
useripban();

/**
 * Cookie Cleanup
 */
if(isset($_COOKIE['pwdcheck']) && $groupid == 'guest') Cookie('pwdcheck', '', 0);

/**
 * Load User Permission Group
 */
if(!@include "./data/groupdb/group_$groupid.php")
    include "./data/groupdb/group_default.php";

/**
 * Admin Detection
 */
$surpadmin = $manager;
if (file_exists("data/admin/$htfid.php") && $htfid != '')
    $manager = $htfid;

/*
 * ===== HTF Board Common Functions =====
